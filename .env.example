# Claura — environment variables
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

DATABASE_URL=postgresql+asyncpg://claura:claura@db:5432/claura
REDIS_URL=redis://redis:6379
SECRET_KEY=change-this-to-a-long-random-string-in-production

# vLLM — local inference server (must be running before starting Claura)
VLLM_URL=http://localhost:8001/v1/completions
VLLM_MODEL=legal-risk-classifier
